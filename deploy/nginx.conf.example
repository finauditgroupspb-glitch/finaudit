# Пример защитного reverse proxy перед Next.js.
# Используйте вместе с CDN/WAF. Не публикуйте Next.js напрямую в интернет.

limit_req_zone $binary_remote_addr zone=site_per_ip:20m rate=20r/s;
limit_req_zone $binary_remote_addr zone=contact_per_ip:10m rate=2r/m;
limit_conn_zone $binary_remote_addr zone=connections_per_ip:10m;

upstream finaudit_next {
  server 127.0.0.1:3000;
  keepalive 32;
}

server {
  listen 443 ssl http2;
  server_name audit-d.ru www.audit-d.ru;

  server_tokens off;
  client_max_body_size 16k;
  client_body_timeout 10s;
  client_header_timeout 10s;
  keepalive_timeout 15s;
  send_timeout 15s;

  # Укажите реальные сертификаты или используйте сертификат origin-сервера CDN.
  ssl_certificate /etc/letsencrypt/live/audit-d.ru/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/audit-d.ru/privkey.pem;
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_session_cache shared:SSL:20m;
  ssl_session_timeout 1d;

  location = /api/contact {
    limit_req zone=contact_per_ip burst=3 nodelay;
    limit_conn connections_per_ip 4;

    proxy_pass http://finaudit_next;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_connect_timeout 3s;
    proxy_read_timeout 10s;
    proxy_send_timeout 10s;
    proxy_request_buffering on;
  }

  location / {
    limit_req zone=site_per_ip burst=80 nodelay;
    limit_conn connections_per_ip 30;

    proxy_pass http://finaudit_next;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_connect_timeout 3s;
    proxy_read_timeout 30s;
    proxy_send_timeout 30s;
  }
}
